msgstr "OpenAI temporarily unavailable."

msgid "Orphan"
msgstr "Orphan"

msgid "Orphan  -  zero linków IN. Niewidoczny."
msgstr "Orphan — zero IN links. Invisible to crawlers."

msgid "Orphany"
msgstr "Orphans"

msgid "Orphany to strony bez linków przychodzących — Google może ich nie zaindeksować. LOOM zasugeruje linki z powiązanych artykułów."
msgstr "Orphans are pages without incoming links — Google may not index them. LOOM will suggest links from related articles."

msgid "Oznacz strony jako money pages klikając ⭐ w tabeli postów."
msgstr "Mark pages as money pages by clicking ⭐ in the posts table."

msgid "Pierścienie"
msgstr "Rings"

msgid "Placement quality 📍"
msgstr "Placement quality 📍"

