msgstr "Priority 1-5 — the higher, the more equity LOOM directs to this page."

msgid "Priorytet głębokich stron"
msgstr "Deep page priority"

msgid "Priorytet klastra"
msgstr "Cluster priority"

msgid "Priorytet money pages ⭐"
msgstr "Money page priority ⭐"

msgid "Priorytet orphan pages"
msgstr "Orphan page priority"

msgid "Priorytet wyższych tierów"
msgstr "Higher tier priority"

