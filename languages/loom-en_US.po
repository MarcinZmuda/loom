msgstr "Internal link graph visualization: rings, scatter, keywords, anchors."

msgid "Wklej zawartość pliku JSON."
msgstr "Paste the JSON file contents."

msgid "Wklej zawartość pliku JSON:"
msgstr "Paste the JSON file contents:"

